# ── IA (server-side únicamente) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REEMPLAZA_ESTA_CLAVE
CHAT_MODEL=claude-haiku-4-5-20251001

# ── API FastAPI (Fase 0) ──────────────────────────────────────────────────────
# SQLite por defecto (local/tests). En prod usa Postgres (Neon), p.ej:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=sqlite:///data/finance_api.db
JWT_SECRET=REEMPLAZA_CON_CADENA_ALEATORIA_DE_32+_BYTES
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=30
CORS_ORIGINS=http://localhost:5173

# ── Importación de extractos (retroactive_import.py) ─────────────────────────
# URL del Google Apps Script web app con el _secret ya incluido como query param.
# Lo encuentras en: Apps Script → Implementar → Administrar implementaciones → URL
WEBHOOK_URL=https://script.google.com/macros/s/REEMPLAZA_CON_TU_ID/exec?_secret=REEMPLAZA_CON_TU_SECRET

# ── Frontend PWA ──────────────────────────────────────────────────────────────
# El secreto del webhook NO va en el bundle: en prod la PWA usa el proxy de
# Cloudflare Pages (functions/api/proxy.js en la raíz del repo). WEBHOOK_URL y WEBHOOK_SECRET
# se configuran como variables de entorno en el proyecto de Cloudflare Pages.
VITE_API_URL=http://localhost:8000
